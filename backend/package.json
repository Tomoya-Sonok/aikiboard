{
  "name": "aikiboard-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.node.ts",
    "dev:wrangler": "wrangler dev --remote",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "test:ci": "vitest run --silent --passWithNoTests",
    "test:watch": "vitest --watch",
    "check": "biome check . && tsc --noEmit",
    "check:fix": "biome check . --write"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.7.2",
    "@supabase/supabase-js": "^2.49.4",
    "hono": "^4.12.11",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^22",
    "dotenv-cli": "^10.0.0",
    "happy-dom": "^18.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.54.0"
  }
}
